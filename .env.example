# DUALMIND VPS PIPELINE - Environment template
# Copy this file to .env and fill values locally on the VPS.
# Never commit real API keys, tokens, passwords, or secrets.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
APP_ENV=development
APP_TIMEZONE=UTC
APP_DATA_DIR=./data
APP_OUTPUT_DIR=./output
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# VPS / Docker / n8n
# Compatible target: Hetzner CAX41, Ubuntu 22.04 ARM64.
# -----------------------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=change_me
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_ENCRYPTION_KEY=change_me_32_chars_minimum
WEBHOOK_URL=http://localhost:5678/

# -----------------------------------------------------------------------------
# Local storage
# -----------------------------------------------------------------------------
SQLITE_DB_PATH=./data/dualmind.db
TEMP_DIR=./tmp
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# -----------------------------------------------------------------------------
# AI providers
# -----------------------------------------------------------------------------
CLAUDE_API_KEY=replace_with_claude_api_key
ANTHROPIC_API_KEY=replace_with_claude_sonnet_key
ANTHROPIC_MODEL=replace_with_claude_sonnet_model

ELEVENLABS_API_KEY=replace_with_elevenlabs_key
ELEVENLABS_VOICE_ID=replace_with_voice_id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

REPLICATE_API_TOKEN=replace_with_replicate_token
REPLICATE_MODEL=replace_with_replicate_model_slug

# Whisper can be local or API-backed depending on the future implementation.
WHISPER_PROVIDER=local
WHISPER_MODEL=base
OPENAI_API_KEY=replace_only_if_using_openai_whisper_api

# -----------------------------------------------------------------------------
# Google Drive / YouTube
# Prefer OAuth/service-account files mounted outside git-tracked folders.
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/opt/dualmind/secrets/google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=replace_with_drive_folder_id
YOUTUBE_API_KEY=replace_with_youtube_api_key
YOUTUBE_CLIENT_SECRET_FILE=/opt/dualmind/secrets/youtube-client-secret.json
YOUTUBE_UPLOAD_PRIVACY_STATUS=private

# -----------------------------------------------------------------------------
# WhatsApp Business Cloud API
# -----------------------------------------------------------------------------
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=replace_with_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=replace_with_business_account_id
WHATSAPP_ACCESS_TOKEN=replace_with_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace_with_verify_token
